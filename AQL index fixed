    flex-shrink: 0;
  }

  .footer {
    margin: 14px auto 0;
    padding-top: 12px;
    border-top: 1px solid var(--border);
    font-size: 0.66rem;
    color: var(--text-muted);
    font-family: 'IBM Plex Mono', monospace;
