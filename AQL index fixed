const SAMPLE_SIZES = {
  A: 2, B: 3, C: 5, D: 8, E: 13, F: 20, G: 32, H: 50,
  J: 80, K: 125, L: 200, M: 315, N: 500, P: 800, Q: 1250, R: 2000
};

const PLAN_MATRIX = {
  "0.065": { A: null, B: null, C: null, D: null, E: null, F: null, G: null, H: null, J: null, K: "down", L: 0, M: "up", N: "down", P: 1, Q: 2, R: 3 },
  "0.1":   { A: null, B: null, C: null, D: null, E: null, F: null, G: null, H: null, J: "down", K: 0, L: "up", M: "down", N: 1, P: 2, Q: 3, R: 5 },
  "0.15":  { A: null, B: null, C: null, D: null, E: null, F: null, G: null, H: "down", J: 0, K: "up", L: "down", M: 1, N: 2, P: 3, Q: 5, R: 7 },
  "0.25":  { A: null, B: null, C: null, D: null, E: null, F: null, G: "down", H: 0, J: "up", K: "down", L: 1, M: 2, N: 3, P: 5, Q: 7, R: 10 },
  "0.4":   { A: null, B: null, C: null, D: null, E: null, F: "down", G: 0, H: "up", J: "down", K: 1, L: 2, M: 3, N: 5, P: 7, Q: 10, R: 14 },
  "0.65":  { A: null, B: null, C: null, D: null, E: "down", F: 0, G: "up", H: "down", J: 1, K: 2, L: 3, M: 5, N: 7, P: 10, Q: 14, R: 21 },
  "1.0":   { A: null, B: null, C: null, D: "down", E: 0, F: "up", G: "down", H: 1, J: 2, K: 3, L: 5, M: 7, N: 10, P: 14, Q: 21, R: "up" },
  "1.5":   { A: null, B: null, C: "down", D: 0, E: "up", F: "down", G: 1, H: 2, J: 3, K: 5, L: 7, M: 10, N: 14, P: 21, Q: "up", R: "up" },
  "2.5":   { A: null, B: "down", C: 0, D: "up", E: "down", F: 1, G: 2, H: 3, J: 5, K: 7, L: 10, M: 14, N: 21, P: "up", Q: "up", R: "up" },
  "4.0":   { A: "down", B: 0, C: "up", D: "down", E: 1, F: 2, G: 3, H: 5, J: 7, K: 10, L: 14, M: 21, N: "up", P: "up", Q: "up", R: "up" },
  "6.5":   { A: 0, B: "up", C: "down", D: 1, E: 2, F: 3, G: 5, H: 7, J: 10, K: 14, L: 21, M: "up", N: "up", P: "up", Q: "up", R: "up" },
  "10.0":  { A: "down", B: "down", C: 1, D: 2, E: 3, F: 5, G: 7, H: 10, J: 14, K: 21, L: "up", M: "up", N: "up", P: "up", Q: "up", R: "up" }
};

function getCodeLetter(lotSize, level) {
  const levelIndex = { I: 2, II: 3, III: 4 };
  const idx = levelIndex[level];
  for (const row of TABLE1) {
    if (lotSize >= row[0] && lotSize <= row[1]) return row[idx];
  }
  return null;
}

function resolveArrow(codeLetter, aqlValue, direction) {
  const startIndex = LETTER_ORDER.indexOf(codeLetter);
  const step = direction === "up" ? -1 : 1;
  for (let i = startIndex + step; i >= 0 && i < LETTER_ORDER.length; i += step) {
    const letter = LETTER_ORDER[i];
    const token = PLAN_MATRIX[aqlValue][letter];
    if (typeof token === "number") {
      return { letter, ac: token, re: token + 1, n: SAMPLE_SIZES[letter], direction };
    }
  }
  return null;
}

function getSamplingPlan(codeLetter, aqlValue, lotSize) {
  if (!codeLetter) return null;

  if (aqlValue === "na") {
    return {
      sourceLetter: codeLetter,
      n: SAMPLE_SIZES[codeLetter],
      ac: 0,
      re: 1,
      notAllowed: true,
      unavailable: false,
      fullInspection: false
    };
  }

  const column = PLAN_MATRIX[aqlValue];
  if (!column) return null;

  const token = column[codeLetter];
  if (typeof token === "number") {
    return {
      sourceLetter: codeLetter,
      n: SAMPLE_SIZES[codeLetter],
      ac: token,
      re: token + 1,
      notAllowed: false,
      unavailable: false,
      fullInspection: false
    };
  }

  if (token === "up" || token === "down") {
    const resolved = resolveArrow(codeLetter, aqlValue, token);
    if (!resolved) {
      return {
        sourceLetter: codeLetter,
        n: null,
        ac: null,
        re: null,
        notAllowed: false,
        unavailable: true,
        fullInspection: false
      };
    }

    if (token === "down" && resolved.n >= lotSize) {
      return {
        sourceLetter: resolved.letter,
        n: lotSize,
        ac: null,
        re: null,
        notAllowed: false,
        unavailable: false,
        fullInspection: true
      };
    }

    return {
      sourceLetter: resolved.letter,
      n: resolved.n,
      ac: resolved.ac,
      re: resolved.re,
      notAllowed: false,
      unavailable: false,
      fullInspection: false
    };
  }

  return {
    sourceLetter: codeLetter,
    n: null,
    ac: null,
    re: null,
    notAllowed: false,
    unavailable: true,
    fullInspection: false
  };
}

let currentPlan = { critical: null, major: null, minor: null };

function calculate() {
  const lotSizeRaw = document.getElementById("lotSize").value;
  const lotSize = parseInt(lotSizeRaw, 10);
  const level = document.getElementById("inspLevel").value;

  if (!Number.isInteger(lotSize) || lotSize < 2) {
    document.getElementById("codeLetter").textContent = "—";
    ["critical", "major", "minor"].forEach(type => {
      currentPlan[type] = null;
      document.getElementById("ss_" + type).textContent = "—";
      document.getElementById("ac_" + type).textContent = "—";
      document.getElementById("re_" + type).textContent = "—";
      setVerdict(type, null);
    });
    return;
  }

  const code = getCodeLetter(lotSize, level);
  document.getElementById("codeLetter").textContent = code || "—";

  ["critical", "major", "minor"].forEach(type => {
    const aqlValue = document.getElementById("aql_" + type).value;
    const plan = getSamplingPlan(code, aqlValue, lotSize);
    currentPlan[type] = plan;

    if (!plan) {
      document.getElementById("ss_" + type).textContent = "—";
      document.getElementById("ac_" + type).textContent = "—";
      document.getElementById("re_" + type).textContent = "—";
      setVerdict(type, null);
      return;
    }

    if (plan.fullInspection) {
      document.getElementById("ss_" + type).textContent = plan.n;
      document.getElementById("ac_" + type).textContent = "100%";
      document.getElementById("re_" + type).textContent = "—";
      setVerdict(type, "fullInspection");
      return;
    }

    document.getElementById("ss_" + type).textContent = plan.n === null ? "—" : plan.n;
    document.getElementById("ac_" + type).textContent = plan.ac === null ? "—" : plan.ac;
    document.getElementById("re_" + type).textContent = plan.re === null ? "—" : plan.re;
    updateVerdict(type);
  });
}

function updateVerdict(type) {
  const rawValue = document.getElementById("def_" + type).value;
  const plan = currentPlan[type];

  if (!plan || rawValue === "") {
    setVerdict(type, null);
    return;
  }

  if (plan.fullInspection) {
    setVerdict(type, "fullInspection");
    return;
  }

  const defects = parseInt(rawValue, 10);
  if (!Number.isInteger(defects) || defects < 0) {
    setVerdict(type, null);
    return;
  }

  if (plan.notAllowed) {
    setVerdict(type, defects === 0 ? "pass" : "fail");
    return;
  }

  if (plan.unavailable || plan.ac === null || plan.re === null) {
    setVerdict(type, "unavailable");
    return;
  }

  if (defects <= plan.ac) setVerdict(type, "pass");
  else setVerdict(type, "fail");
}

function setVerdict(type, result) {
  const box = document.getElementById("verdict_" + type);
  box.className = "verdict-box";

  if (!result) {
    box.classList.add("na");
    box.textContent = "Enter defects found";
    return;
  }

  if (result === "fullInspection") {
    box.classList.add("na");
    box.textContent = "100% inspection required";
    return;
  }

  if (result === "unavailable") {
    box.classList.add("na");
    box.textContent = "AQL plan not available";
    return;
  }

  if (result === "pass") {
    box.classList.add("pass");
    box.textContent = "✓ PASS";
    return;
  }

  box.classList.add("fail");
  box.textContent = "✗ FAIL";
}

calculate();
</script>

